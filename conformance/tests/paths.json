[
  {
    "name": "GetBoard path construction",
    "operation": "GetBoard",
    "method": "GET",
    "path": "/{accountId}/boards/{boardId}.json",
    "pathParams": { "accountId": "999", "boardId": 42 },
    "mockResponses": [
      {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": { "id": 42, "name": "Test", "all_access": true, "created_at": "2026-01-01T00:00:00Z", "url": "https://fizzy.do/999/boards/42" }
      }
    ],
    "assertions": [
      { "type": "requestPath", "expected": "/999/boards/42.json" },
      { "type": "noError" }
    ],
    "tags": ["paths"]
  },
  {
    "name": "GetCard uses cardNumber not ID",
    "operation": "GetCard",
    "method": "GET",
    "path": "/{accountId}/cards/{cardNumber}.json",
    "pathParams": { "accountId": "999", "cardNumber": 123 },
    "mockResponses": [
      {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": { "id": 1, "number": 123, "title": "Test", "status": "active", "has_attachments": false, "closed": false, "postponed": false, "golden": false, "created_at": "2026-01-01T00:00:00Z", "url": "https://fizzy.do/999/cards/123" }
      }
    ],
    "assertions": [
      { "type": "requestPath", "expected": "/999/cards/123.json" },
      { "type": "noError" }
    ],
    "tags": ["paths"]
  },
  {
