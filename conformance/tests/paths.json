  {
    "name": "CreateDirectUpload path has no .json suffix",
    "operation": "CreateDirectUpload",
    "method": "POST",
    "path": "/{accountId}/rails/active_storage/direct_uploads",
    "pathParams": { "accountId": "999" },
    "requestBody": { "filename": "test.png", "content_type": "image/png", "byte_size": 1024, "checksum": "abc123" },
    "mockResponses": [
      {
        "status": 201,
        "headers": { "Content-Type": "application/json" },
        "body": { "id": 1, "key": "abc", "filename": "test.png", "content_type": "image/png", "byte_size": 1024, "checksum": "abc123", "direct_upload": { "url": "https://storage.example.com/upload", "headers": { "Content-Type": "image/png" } } }
      }
    ],
    "assertions": [
      { "type": "requestPath", "expected": "/999/rails/active_storage/direct_uploads" },
      { "type": "noError" }
    ],
    "tags": ["paths"]
  },
  {
    "name": "Session path has no account prefix",
