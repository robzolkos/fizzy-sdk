    "path": "/{accountId}/boards/{boardId}/webhooks.json",
    "pathParams": { "accountId": "999", "boardId": 456 },
    "requestBody": { "name": "Test", "url": "https://example.com/hook" },
    "mockResponses": [
      {
        "status": 201,
