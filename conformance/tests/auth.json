[
  {
    "name": "Bearer token injected in Authorization header",
    "description": "SDK must set Authorization: Bearer header on every request",
    "operation": "ListBoards",
    "method": "GET",
    "path": "/{accountId}/boards.json",
    "pathParams": { "accountId": "999" },
    "mockResponses": [
      {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": []
      }
    ],
    "assertions": [
      { "type": "headerPresent", "path": "Authorization" },
      { "type": "noError" }
    ],
    "tags": ["auth"]
  },
  {
    "name": "User-Agent header includes SDK identifier",
    "description": "SDK must send a User-Agent header identifying the SDK and version",
    "operation": "GetBoard",
    "method": "GET",
    "path": "/{accountId}/boards/{boardId}.json",
    "pathParams": { "accountId": "999", "boardId": 1 },
    "mockResponses": [
      {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": { "id": 1, "name": "Test", "all_access": true, "created_at": "2026-01-01T00:00:00Z", "url": "https://fizzy.do/999/boards/1" }
      }
    ],
    "assertions": [
      { "type": "headerPresent", "path": "User-Agent" },
      { "type": "noError" }
    ],
    "tags": ["auth"]
  }
]
