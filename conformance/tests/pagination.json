[
  {
    "name": "List returns first page with Link header",
    "description": "Paginated list operations should return results and respect Link header",
    "operation": "ListBoards",
    "method": "GET",
    "path": "/{accountId}/boards.json",
    "pathParams": { "accountId": "999" },
    "mockResponses": [
      {
        "status": 200,
        "headers": {
          "Content-Type": "application/json",
          "Link": "<https://fizzy.do/999/boards.json?page=2>; rel=\"next\""
        },
        "body": [
          { "id": 1, "name": "Board 1", "all_access": true, "created_at": "2026-01-01T00:00:00Z", "url": "https://fizzy.do/999/boards/1" }
        ]
      }
    ],
    "assertions": [
      { "type": "requestCount", "expected": 1 },
      { "type": "statusCode", "expected": 200 },
      { "type": "noError" }
    ],
    "tags": ["pagination"]
  },
  {
    "name": "Same-origin pagination follows Link to second page",
    "description": "SDK should follow same-origin Link headers for pagination",
    "operation": "ListBoards",
    "method": "GET",
    "path": "/{accountId}/boards.json",
    "pathParams": { "accountId": "999" },
    "configOverrides": { "baseUrl": "http://localhost:3000" },
    "mockResponses": [
      {
        "status": 200,
        "headers": {
          "Content-Type": "application/json",
          "Link": "<http://localhost:3000/999/boards.json?page=2>; rel=\"next\""
        },
        "body": [
          { "id": 1, "name": "Board 1", "all_access": true, "created_at": "2026-01-01T00:00:00Z", "url": "http://localhost:3000/999/boards/1" }
        ]
      },
      {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": [
          { "id": 2, "name": "Board 2", "all_access": false, "created_at": "2026-01-02T00:00:00Z", "url": "http://localhost:3000/999/boards/2" }
        ]
      }
    ],
    "assertions": [
      { "type": "requestCount", "expected": 2 },
      { "type": "noError" }
    ],
    "tags": ["pagination", "link-header"]
  }
]
