[
  {
    "name": "CreateSession sends email_address field",
    "operation": "CreateSession",
    "method": "POST",
    "path": "/session.json",
    "requestBody": { "email_address": "test@example.com" },
    "mockResponses": [
      {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": { "pending_authentication_token": "pat_12345" }
      }
    ],
    "assertions": [
      { "type": "requestBodyField", "expected": "email_address" },
      { "type": "noError" }
    ],
    "tags": ["request-shapes"]
  },
  {
    "name": "CreateCardReaction sends content field",
    "operation": "CreateCardReaction",
    "method": "POST",
    "path": "/{accountId}/cards/{cardNumber}/reactions.json",
    "pathParams": { "accountId": "999", "cardNumber": 123 },
    "requestBody": { "content": "👍" },
    "mockResponses": [
      {
        "status": 201,
        "headers": { "Content-Type": "application/json" },
        "body": { "id": 1, "content": "👍", "reacter": { "id": 1, "name": "Test User" }, "url": "https://fizzy.do/999/cards/123/reactions/1", "created_at": "2026-01-01T00:00:00Z" }
      }
    ],
    "assertions": [
      { "type": "requestBodyField", "expected": "content" },
      { "type": "noError" }
    ],
    "tags": ["request-shapes"]
  },
