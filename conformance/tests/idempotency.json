[
  {
    "name": "PATCH retries on 503 (idempotent)",
    "description": "PATCH operations are naturally idempotent and should be retried",
    "operation": "UpdateBoard",
    "method": "PATCH",
    "path": "/{accountId}/boards/{boardId}",
    "pathParams": { "accountId": "999", "boardId": 1 },
    "requestBody": { "name": "Updated" },
    "mockResponses": [
      {
        "status": 503,
        "headers": { "Content-Type": "application/json" },
        "body": { "error": "Service unavailable" }
      },
      {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": { "id": 1, "name": "Updated", "all_access": true, "created_at": "2026-01-01T00:00:00Z", "url": "https://fizzy.do/999/boards/1" }
      }
    ],
    "assertions": [
      { "type": "requestCount", "expected": 2 },
      { "type": "noError" }
    ],
    "tags": ["idempotency"]
  },
  {
    "name": "DELETE retries on 503 (idempotent)",
    "description": "DELETE operations are naturally idempotent and should be retried",
    "operation": "DeleteBoard",
    "method": "DELETE",
    "path": "/{accountId}/boards/{boardId}",
    "pathParams": { "accountId": "999", "boardId": 1 },
    "mockResponses": [
      {
        "status": 503,
        "headers": { "Content-Type": "application/json" },
        "body": { "error": "Service unavailable" }
      },
      {
        "status": 204,
        "headers": {},
        "body": null
      }
    ],
    "assertions": [
      { "type": "requestCount", "expected": 2 },
      { "type": "noError" }
    ],
    "tags": ["idempotency"]
  },
  {
    "name": "POST create does NOT retry on 503",
    "description": "POST create operations are not idempotent and must not be retried",
    "operation": "CreateCard",
    "method": "POST",
    "path": "/{accountId}/cards.json",
    "pathParams": { "accountId": "999" },
    "requestBody": { "title": "Test Card" },
    "mockResponses": [
      {
        "status": 503,
        "headers": { "Content-Type": "application/json" },
        "body": { "error": "Service unavailable" }
      }
    ],
    "assertions": [
      { "type": "requestCount", "expected": 1 },
      { "type": "statusCode", "expected": 503 }
    ],
    "tags": ["idempotency"]
  },
  {
    "name": "DestroySession DELETE does NOT retry (contract exception)",
    "description": "DestroySession is a one-time operation — even though it is DELETE, it must not be retried (RD-9b)",
    "operation": "DestroySession",
    "method": "DELETE",
    "path": "/session.json",
    "mockResponses": [
      {
        "status": 503,
        "headers": { "Content-Type": "application/json" },
        "body": { "error": "Service unavailable" }
      }
    ],
    "assertions": [
      { "type": "requestCount", "expected": 1 },
      { "type": "statusCode", "expected": 503 }
    ],
    "tags": ["idempotency", "sessions"]
  }
]
