#!/usr/bin/env bash
set -euo pipefail

# Generate behavior-model.json from the Smithy AST.
# Input:  spec/build/smithy/source/model/model.json (Smithy AST)
# Output: behavior-model.json

AST="spec/build/smithy/source/model/model.json"
OUTPUT="${1:-behavior-model.json}"

if [ ! -f "$AST" ]; then
  echo "ERROR: Smithy AST not found at $AST. Run 'make smithy-build' first." >&2
  exit 1
fi

jq '{
  "$schema": "https://fizzy.do/schemas/behavior-model.json",
  "version": "1.0.0",
  "generated": true,
  "operations": (
    [.shapes | to_entries[] |
      select(.value.type == "operation") |
      {
        key: (.key | split("#")[1]),
        value: {
          readonly: (if .value.traits["smithy.api#readonly"] != null then true else null end),
          idempotent: (
            if .value.traits["smithy.api#idempotent"] != null then true
            elif .value.traits["fizzy.traits#fizzyIdempotent"] != null then true
            else null end
          ),
          pagination: (
            if .value.traits["fizzy.traits#fizzyPagination"] != null then
              .value.traits["fizzy.traits#fizzyPagination"] | {
                style: .style,
                page_param: .pageParam,
                max_page_size: .maxPageSize
              }
            else null end
          ),
          retry: (
            if .value.traits["fizzy.traits#fizzyRetry"] != null then
              .value.traits["fizzy.traits#fizzyRetry"] | {
                max: .maxAttempts,
                base_delay_ms: .baseDelayMs,
                backoff: .backoff,
                retry_on: .retryOn
              }
            else null end
          )
        } | with_entries(select(.value != null))
      }
    ] | from_entries
  ),
  "redaction": (
    [.shapes | to_entries[] |
      select(.value.type == "structure") |
      select(.value.members != null) |
      . as $shape |
      [.value.members | to_entries[] |
        select(.value.traits["fizzy.traits#fizzySensitive"] != null) |
        {
          path: ("$." + .key),
          category: .value.traits["fizzy.traits#fizzySensitive"].category,
          redact: (.value.traits["fizzy.traits#fizzySensitive"].redact // false)
        }
      ] |
      select(length > 0) |
      {
        key: ($shape.key | split("#")[1]),
        value: .
      }
    ] | from_entries
  ),
  "sensitiveTypes": (
    [.shapes | to_entries[] |
      select(.value.traits["smithy.api#sensitive"] != null) |
      .key | split("#")[1]
    ] | sort
  )
}' "$AST" > "$OUTPUT"

echo "Generated $OUTPUT"
